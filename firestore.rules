rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Strictly Default-Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // RBAC Helpers (auth-model.md §2)
    function isGuest() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isFarmer() {
      return isSignedIn() && !isGuest();
    }

    function isFPOLead() {
      return isSignedIn() && request.auth.token.role == 'fpo_lead';
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null &&
             request.auth.token.email.matches('.*@aikrushimitra\\.com$');
    }

    // ==========================================
    // VALIDATION BLUEPRINTS
    // ==========================================

    function isValidUserProfile(data) {
      return data.keys().hasAll(['name', 'village', 'district', 'landSize', 'crop']) &&
             data.keys().size() <= 15 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.village is string && data.village.size() > 0 && data.village.size() <= 100 &&
             data.district is string && data.district.size() > 0 && data.district.size() <= 100 &&
             data.landSize is string && data.landSize.size() > 0 && data.landSize.size() <= 50 &&
             data.crop is string && data.crop.size() > 0 && data.crop.size() <= 100 &&
             (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 150)) &&
             (!data.keys().hasAny(['picture']) || (data.picture is string && data.picture.size() <= 500)) &&
             (!data.keys().hasAny(['joinedAt']) || data.joinedAt is int) &&
             (!data.keys().hasAny(['lastLogin']) || data.lastLogin is int);
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'view', 'location', 'userAgent']) &&
             data.keys().size() <= 12 &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 128 &&
             data.timestamp is int &&
             data.view is string && data.view.size() > 0 && data.view.size() <= 100 &&
             data.location is string && data.location.size() <= 150 &&
             data.userAgent is string && data.userAgent.size() <= 512;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['userId', 'startedAt', 'messageCount', 'language']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.startedAt is int &&
             data.messageCount is int && data.messageCount >= 0 &&
             data.language is string && data.language in ['mr', 'hi', 'en'];
    }

    function isValidDiagnosis(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'cropType', 'disease', 'confidence', 'timestamp']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.cropType is string && data.cropType.size() > 0 &&
             data.disease is string &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 1 &&
             data.timestamp is int;
    }

    // ==========================================
    // COLLECTION RULES (database-schema.md §2)
    // ==========================================

    // 2.1 User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false; // Block scraping

      allow create: if isOwner(userId) && 
                       isValidId(userId) && 
                       isValidUserProfile(request.resource.data);

      allow update: if isOwner(userId) && 
                       isValidId(userId) && 
                       isValidUserProfile(request.resource.data) &&
                       (!resource.data.keys().hasAny(['joinedAt']) || 
                        request.resource.data.joinedAt == resource.data.joinedAt);

      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // 2.2 Conversations (AI Chat History)
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isFarmer() && 
                       isValidConversation(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && 
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == resource.data.userId; // Cannot change ownership
      allow delete: if false; // Conversations are immutable

      // Subcollection: messages
      match /messages/{messageId} {
        allow read: if isSignedIn() && 
                       get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid;
        allow create: if isFarmer() &&
                        get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid;
        allow update, delete: if false; // Messages are append-only
      }
    }

    // 2.3 Diagnoses (Disease Scan Results)
    match /diagnoses/{diagnosisId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn(); // Users can list their own scans (filtered by client)

      allow create: if isFarmer() && 
                       isValidDiagnosis(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid;

      // Guests limited to 2 scans (enforced at API layer, not Firestore — 
      // Firestore cannot count documents per user efficiently)

      // Allow user to add feedback to their own diagnosis
      allow update: if isSignedIn() && 
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedback']);

      allow delete: if false; // Diagnoses are immutable
    }

    // 2.4 Market Prices (APMC Data)
    match /marketPrices/{priceId} {
      allow read: if true; // Public read — market prices are open data
      allow list: if true;
      allow create, update: if isAdmin(); // Only batch writes from scheduled functions
      allow delete: if isAdmin();
    }

    // 2.5 Crops (Reference Data)
    match /crops/{cropId} {
      allow read: if true; // Public reference data
      allow list: if true;
      allow create, update, delete: if isAdmin(); // Admin-only editorial
    }

    // 2.6 Diseases (Reference Data)
    match /diseases/{diseaseId} {
      allow read: if true; // Public reference data
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    // 2.7 Government Schemes
    match /schemes/{schemeId} {
      allow read: if true; // Public scheme catalog
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    // 2.8 Activity Logs (Telemetry)
    match /activityLogs/{logId} {
      allow get: if isSignedIn() && isValidId(logId);
      allow list: if isAdmin(); // Only admins can query bulk logs

      allow create: if isSignedIn() && 
                       isValidId(logId) && 
                       isValidActivityLog(request.resource.data);
                       
      allow update, delete: if false; // Activity logs are immutable
    }

    // 2.9 Alerts (Pest Outbreak + Price Alerts)
    match /alerts/{alertId} {
      allow read: if true; // Public safety data — outbreak warnings should be visible to all
      allow list: if true;

      // Authenticated farmers can report outbreaks
      allow create: if isFarmer();

      // Only system/admin can update alert severity or close alerts
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 2.10 Content (Blog Posts, Knowledge Articles)
    match /content/{contentId} {
      allow read: if true; // Public content
      allow list: if true;
      allow create, update, delete: if isAdmin(); // Editorial workflow
    }
  }
}

{
  "name": "ai-krushi-mitra-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "npm run build && node server.js",
    "clean": "powershell -Command \"if (Test-Path apps/web/.next) { Remove-Item -Recurse -Force apps/web/.next }; if (Test-Path apps/web/out) { Remove-Item -Recurse -Force apps/web/out }\"",
    "build": "npm run build --workspace=@akm/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "dependencies": {
    "@google/genai": "*",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
